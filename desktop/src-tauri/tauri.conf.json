{
  "build": {
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "package": {
    "productName": "Nous Control Center",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": { "all": true, "request": true, "scope": ["http://**", "https://**"] },
      "shell": { "open": true },
      "fs": { "readFile": true, "writeFile": true, "scope": ["$APP/**", "$HOME/**"] },
      "path": { "all": true },
      "window": { "all": true }
    },
    "windows": [{
      "title": "Nous Control Center",
      "width": 1200,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false
    }],
    "security": {
      "csp": "default-src 'self'; connect-src http://* https://*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  }
}
