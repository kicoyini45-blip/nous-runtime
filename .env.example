# Nous server environment template.
# Copy to remote_terminal/.env or set equivalent NOUS_* variables in your process manager.

export NOUS_BRAIN_HOST="0.0.0.0"
export NOUS_BRAIN_PORT="8770"
export NOUS_LLM_API_KEY="sk-your-key-here"
export NOUS_AUTH_TOKEN="change-me-to-a-strong-random-string"
export NOUS_AGENT_SIGNING_SECRET="change-me-to-another-strong-random-string"

# Optional provider settings.
export NOUS_LLM_API_URL="https://api.example.com/v1/chat/completions"
export NOUS_LLM_MODEL="example-model"

# Keep high-risk capabilities disabled unless explicitly needed.
# export NOUS_ENABLE_PC_SHELL=1
# export NOUS_ENABLE_PHONE_CONTROL=1
# export NOUS_ENABLE_FILE_WRITE=1
